{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "minimumReleaseAge": "7 days",
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "matchCurrentVersion": "!/^0/",
      "automerge": true
    },
    {
      "matchDepTypes": ["dependencies", "devDependencies"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "description": "Lock Python to 3.13 line for Docker and GitHub Actions",
      "matchPackageNames": ["python", "docker.io/library/python"],
      "allowedVersions": "< 3.14.0"
    }
  ],
  "digest": {
    "enabled": false
  },
  "pip_requirements": {
    "managerFilePatterns": ["/^requirements/.*\\.txt$/"]
  },
  "ignoreDeps": ["ghcr.io/the-broke-sommeliers/wine-cellar-web"]
}
